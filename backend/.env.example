# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false

# ── API ───────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1

# ── CORS (comma-separated) ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
